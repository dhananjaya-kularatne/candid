# Copy this to .env or set these as environment variables on your hosting platform (Railway/Render/etc.)

# Database
DB_URL=jdbc:mysql://your-db-host:3306/candid_db?useSSL=true&serverTimezone=UTC
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# JWT — generate a strong random string (32+ chars)
JWT_SECRET=replace-with-a-strong-random-secret-at-least-256-bits

# Cloudinary (from cloudinary.com dashboard)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Gmail SMTP (use an App Password, not your real password)
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_app_password

# Admin account seed (created on first boot if not exists)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeThisNow!

# CORS — comma-separated list of your frontend origin(s), no trailing slash
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Production: use 'validate' to prevent schema mutations
JPA_DDL_AUTO=validate
